{
  "name": "storycraft-mobile",
  "version": "1.0.4",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:apk:local": "powershell -ExecutionPolicy Bypass -File scripts/build-apk.ps1",
    "download:asr-models": "powershell -ExecutionPolicy Bypass -File scripts/download-asr-models.ps1",
    "build:apk:debug": "cd android && gradlew.bat assembleDebug",
    "build:apk:eas": "eas build --platform android --profile preview --non-interactive"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^7.0.14",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-file-system": "~18.0.0",
    "expo-image-manipulator": "~13.0.6",
    "expo-intent-launcher": "~12.0.2",
    "expo-linking": "~7.0.0",
    "expo-print": "~14.0.0",
    "expo-router": "~4.0.0",
    "expo-sharing": "~13.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.0",
    "typescript": "~5.3.0"
  },
  "private": true
}
